{
  "name": "mcprec",
  "version": "0.5.0",
  "description": "Record & replay any MCP server. VCR for the Model Context Protocol.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mcprec": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "GOALS.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p . && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "lint": "tsc -p . --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "ai-agents",
    "testing",
    "vcr",
    "fixtures",
    "jsonrpc",
    "cli"
  ],
  "homepage": "https://github.com/erphq/mcprec",
  "repository": {
    "type": "git",
    "url": "https://github.com/erphq/mcprec.git"
  },
  "bugs": {
    "url": "https://github.com/erphq/mcprec/issues"
  }
}
